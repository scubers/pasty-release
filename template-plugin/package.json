{
  "name": "@pasty/template-plugin",
  "private": true,
  "version": "0.1.0",
  "description": "Source-based template plugin for Pasty detector, renderer, and action authoring.",
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "vite --host 127.0.0.1 --open /src/ui/preview/preview-host/index.html",
    "dev:renderer": "vite --host 127.0.0.1 --open /src/ui/preview/preview-host/index.html?view=renderer",
    "dev:action": "vite --host 127.0.0.1 --open /src/ui/preview/preview-host/index.html?view=action",
    "build:runtime": "node ./scripts/build-runtime.mjs",
    "build:ui": "node ./scripts/build-ui.mjs",
    "verify:build": "node ./scripts/verify-build.mjs",
    "build": "npm run clean && npm run build:runtime && npm run build:ui && npm run verify:build",
    "test": "node --test ./tests/**/*.test.cjs"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "esbuild": "^0.25.0",
    "vite": "^5.4.14"
  }
}
